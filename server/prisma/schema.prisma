generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id              String           @id @default(uuid())
  name            String
  domain          String?          @unique
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  customers       Customer[]
  inventoryItems  InventoryItem[]
  menuItems       MenuItem[]
  orders          Order[]
  payments        Payment[]
  reservations    Reservation[]
  rolePermissions RolePermission[]
  tables          Table[]
  settings        TenantSettings?
  users           User[]
  serviceRequests ServiceRequest[]
  activities      Activity[]
  activityBookings ActivityBooking[]
  shifts          Shift[]
  clockEvents     ClockEvent[]
  vendors         Vendor[]
  purchaseOrders  PurchaseOrder[]
  inventoryAuditLogs InventoryAuditLog[]
}

model Vendor {
  id              String           @id @default(uuid())
  tenantId        String
  name            String
  contactName     String?
  email           String?
  phone           String?
  categories      String[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  purchaseOrders  PurchaseOrder[]

  @@index([tenantId])
}

model PurchaseOrder {
  id              String              @id @default(uuid())
  tenantId        String
  vendorId        String
  status          String              @default("DRAFT") // DRAFT, SENT, RECEIVED
  totalCost       Decimal             @db.Decimal(10,2)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  tenant          Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  vendor          Vendor              @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  items           PurchaseOrderItem[]

  @@index([tenantId])
}

model PurchaseOrderItem {
  id               String        @id @default(cuid())
  purchaseOrderId  String
  inventoryItemId  String
  orderedQty       Decimal       @db.Decimal(10,2)
  receivedQty      Decimal?      @db.Decimal(10,2)
  unitCost         Decimal       @db.Decimal(10,2)
  createdAt        DateTime      @default(now())
  purchaseOrder    PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  inventoryItem    InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)

  @@index([purchaseOrderId])
  @@index([inventoryItemId])
}

model InventoryAuditLog {
  id              String           @id @default(uuid())
  tenantId        String
  inventoryItemId String
  previousQty     Decimal          @db.Decimal(10,2)
  newQty          Decimal          @db.Decimal(10,2)
  adjustmentType  String           // AUDIT, PURCHASE, SALE, WASTE
  reason          String?
  userId          String?
  createdAt       DateTime         @default(now())
  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  inventoryItem   InventoryItem    @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([tenantId, createdAt])
}

model User {
  id        String   @id @default(uuid())
  tenantId  String
  email     String   @unique
  password  String
  firstName String
  lastName  String
  role        String
  hourlyRate  Decimal  @default(0) @db.Decimal(10,2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  status      String   @default("ACTIVE")
  orders      Order[]
  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  shifts      Shift[]
  clockEvents ClockEvent[]
  refreshTokens RefreshToken[]

  @@unique([tenantId, email])
  @@index([tenantId])
}

model RefreshToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  tenantId  String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model MenuItem {
  id          String      @id @default(uuid())
  tenantId    String
  name        String
  description String?
  price       Decimal     @db.Decimal(10,2)
  categoryId  String?
  isAvailable Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orderItems  OrderItem[]

  @@index([tenantId])
}

model Order {
  id          String      @id @default(uuid())
  tenantId    String
  tableId     String?
  userId      String?
  status      String
  totalAmount Decimal     @db.Decimal(10,2)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  table       Table?      @relation(fields: [tableId], references: [id], onDelete: SetNull)
  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user        User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  items       OrderItem[]
  payments    Payment[]

  @@index([tenantId])
  @@index([tenantId, status])
}

model OrderItem {
  id         String   @id @default(uuid())
  orderId    String
  menuItemId String
  quantity   Int
  unitPrice  Decimal  @db.Decimal(10,2)
  subtotal   Decimal  @db.Decimal(10,2)
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Restrict)
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Table {
  id           String        @id @default(uuid())
  tenantId     String
  number       String
  capacity     Int
  isOccupied   Boolean       @default(false)
  type         String        @default("TABLE")
  x            Int           @default(0)
  y            Int           @default(0)
  zone         String        @default("Indoor")
  shape        String        @default("SQUARE") // SQUARE, ROUND, RECTANGLE
  orders       Order[]
  reservations Reservation[]
  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, number])
  @@index([tenantId])
}

model Payment {
  id        String   @id @default(uuid())
  tenantId  String
  orderId   String
  amount    Decimal  @db.Decimal(10,2)
  status    String
  method    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Restrict)
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, createdAt])
}

model Reservation {
  id         String    @id @default(uuid())
  tenantId   String
  tableId    String?
  guestName  String
  guestPhone String?
  guestEmail String?
  guestCount Int
  startTime  DateTime
  endTime    DateTime?
  status     String    @default("PENDING")
  notes      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  table      Table?    @relation(fields: [tableId], references: [id], onDelete: SetNull)
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, startTime]) //startTime is used for date filtering in this model
}

model Customer {
  id            String   @id @default(uuid())
  tenantId      String
  name          String
  email         String?
  phone         String?
  totalSpend    Decimal  @default(0) @db.Decimal(10,2)
  visitCount    Int      @default(0)
  loyaltyPoints Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, email])
  @@index([tenantId])
}

model InventoryItem {
  id           String   @id @default(uuid())
  tenantId     String
  name         String
  sku          String?
  unit         String
  currentStock Decimal  @default(0) @db.Decimal(10,2)
  minStock     Decimal  @default(0) @db.Decimal(10,2)
  costPerUnit  Decimal  @default(0) @db.Decimal(10,2)
  supplierId   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  inventoryAuditLogs InventoryAuditLog[]
  purchaseOrderItems PurchaseOrderItem[]

  @@unique([tenantId, sku])
  @@index([tenantId])
}

model TenantSettings {
  id           String   @id @default(uuid())
  tenantId     String   @unique
  currency     String   @default("KES")
  taxRate      Decimal  @default(16.0) @db.Decimal(10,2)
  logoUrl      String?
  timezone     String   @default("Africa/Nairobi")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  displayName  String?
  primaryColor String?  @default("#008B8B")
  outletType   String?  @default("RESTAURANT") // RESTAURANT, BAR, CAFE, ROOM_SERVICE, POOL_BAR
  operatingHours Json?  // { Mon: { open, close }, ... }
  receiptConfig  Json?  // { header, footer, showTax, showLogo }
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model RolePermission {
  id          String   @id @default(uuid())
  tenantId    String
  role        String
  permissions String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, role])
}

model ServiceRequest {
  id          String   @id @default(uuid())
  tenantId    String
  roomNumber  String
  category    String
  description String
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, status])
}

model Activity {
  id             String            @id @default(uuid())
  tenantId       String
  name           String
  description    String
  duration       Int
  price          Decimal           @db.Decimal(10,2)
  maxCapacity    Int
  availableSlots Int
  imageUrl       String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  tenant         Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bookings       ActivityBooking[]

  @@index([tenantId])
}

model ActivityBooking {
  id         String   @id @default(uuid())
  tenantId   String
  activityId String
  roomNumber String
  guestName  String
  slotTime   DateTime
  status     String   @default("CONFIRMED")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  activity   Activity @relation(fields: [activityId], references: [id], onDelete: Restrict)
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model Shift {
  id         String   @id @default(uuid())
  tenantId   String
  userId     String
  date       DateTime @db.Date
  startTime  DateTime
  endTime    DateTime
  station    String
  createdAt  DateTime @default(now())
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, date])
}

model ClockEvent {
  id        String   @id @default(uuid())
  tenantId  String
  userId    String
  type      String   // "IN" or "OUT"
  timestamp DateTime @default(now())
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}
