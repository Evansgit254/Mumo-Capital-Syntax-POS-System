PORT=5000
DATABASE_URL="postgresql://user:password@localhost:5432/mumo_pos?schema=public"
JWT_SECRET="your_access_token_secret_here"
JWT_REFRESH_SECRET="your_refresh_token_secret_here"
FRONTEND_URL="http://localhost:5173"
ALLOWED_ORIGINS=*.yourdomain.com,https://yourdomain.com
NODE_ENV="development"

# Super Admin
SUPER_ADMIN_JWT_SECRET=<strong random string min 32 chars>
SUPER_ADMIN_EMAIL=super@mumo.app
SUPER_ADMIN_PASSWORD=<strong password>

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@mumo.app
SMTP_PASS=<app password>
SMTP_FROM="Mumo POS <noreply@mumo.app>"

# Email (Resend API — alternative to SMTP)
RESEND_API_KEY=re_xxxxxxxxxxxx

# Client URL (for email links)
VITE_CLIENT_URL=http://localhost:5173
